generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationRole {
  OWNER
  ADMIN
  DEVELOPER
  VIEWER
}

enum GenerationJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

model User {
  id                   String                    @id @default(cuid())
  email                String                    @unique
  passwordHash         String
  name                 String?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  createdOrganizations Organization[]            @relation("OrganizationCreator")
  memberships          OrganizationMembership[]
  createdProjects      Project[]                 @relation("ProjectCreator")
  createdVersions      ProjectVersion[]          @relation("ProjectVersionCreator")
  requestedJobs        GenerationJob[]           @relation("GenerationJobRequester")
}

model Organization {
  id                   String                    @id @default(cuid())
  name                 String
  slug                 String                    @unique
  createdByUserId      String
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  createdBy            User                      @relation("OrganizationCreator", fields: [createdByUserId], references: [id])
  memberships          OrganizationMembership[]
  projects             Project[]
}

model OrganizationMembership {
  id                   String            @id @default(cuid())
  organizationId       String
  userId               String
  role                 OrganizationRole
  createdAt            DateTime          @default(now())

  organization         Organization      @relation(fields: [organizationId], references: [id])
  user                 User              @relation(fields: [userId], references: [id])

  @@unique([organizationId, userId])
}

model Project {
  id                   String            @id @default(cuid())
  organizationId       String
  name                 String
  slug                 String
  description          String?
  latestVersionId      String?
  createdByUserId      String
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  organization         Organization      @relation(fields: [organizationId], references: [id])
  createdBy            User              @relation("ProjectCreator", fields: [createdByUserId], references: [id])
  versions             ProjectVersion[]
  generationJobs       GenerationJob[]
}

model ProjectVersion {
  id                   String            @id @default(cuid())
  projectId            String
  versionNumber        Int
  appSpecJson          Json
  specSchemaVersion    String
  createdByUserId      String
  createdAt            DateTime          @default(now())
  notes                String?

  project              Project           @relation(fields: [projectId], references: [id])
  createdBy            User              @relation("ProjectVersionCreator", fields: [createdByUserId], references: [id])
  generationJobs       GenerationJob[]

  @@unique([projectId, versionNumber])
}

model GenerationJob {
  id                   String              @id @default(cuid())
  projectId            String
  projectVersionId     String
  requestedByUserId    String?
  status               GenerationJobStatus @default(QUEUED)
  log                  String?
  artifactPath         String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  startedAt            DateTime?
  finishedAt           DateTime?

  project              Project             @relation(fields: [projectId], references: [id])
  projectVersion       ProjectVersion      @relation(fields: [projectVersionId], references: [id])
  requestedBy          User?               @relation("GenerationJobRequester", fields: [requestedByUserId], references: [id])
  artifacts            GeneratedArtifact[]
}

model GeneratedArtifact {
  id                   String            @id @default(cuid())
  generationJobId      String
  fileName             String
  filePath             String
  checksum             String?
  size                 BigInt?
  createdAt            DateTime          @default(now())

  generationJob        GenerationJob     @relation(fields: [generationJobId], references: [id])
}